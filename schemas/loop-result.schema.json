{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/loop-result.schema.json",
  "title": "Linear Agent Loop Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "reason", "observed"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "no_op", "failed"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issueId", "runId", "loop", "fingerprint"],
      "properties": {
        "issueId": { "type": "string" },
        "runId": { "type": "string" },
        "loop": { "type": "string" },
        "shard": { "type": "string" },
        "workerId": { "type": "string" },
        "fingerprint": { "type": "string" },
        "updatedAt": { "type": "string" },
        "state": { "type": "string" },
        "labelsHash": { "type": "string" },
        "descriptionHash": { "type": "string" },
        "registryVersion": { "type": ["integer", "string"] },
        "memoryVersion": { "type": ["integer", "string"] },
        "leaseId": { "type": "string" }
      }
    },
    "nextState": {
      "type": ["string", "null"],
      "enum": [
        "Triage",
        "Backlog",
        "Discovery",
        "Todo",
        "In Progress",
        "In Review",
        "Done",
        "Canceled",
        "Duplicate",
        null
      ]
    },
    "requestedWorker": {
      "type": ["string", "null"],
      "enum": ["discovery", "memory-reconcile", "repo-manager", "coordinator", null]
    },
    "escalation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["target", "kind", "blocking", "reason"],
      "properties": {
        "target": {
          "type": ["string", "null"],
          "enum": [
            "coordinator",
            "discovery",
            "memory-reconcile",
            "repo-manager",
            null
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "cas_conflict",
            "stale_run",
            "expired_lease",
            "unknown_state",
            "human_or_automation_drift",
            "multi_repo",
            "needs_internal_worker",
            "repo_or_lock_conflict",
            "none"
          ]
        },
        "blocking": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "labelsToAdd": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "labelsToRemove": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "linearComment": {
      "type": "string"
    },
    "memoryPatch": {
      "type": "object",
      "additionalProperties": true
    },
    "repoActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "reason"],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "resolve_repo",
              "clone",
              "fetch",
              "acquire_read_lease",
              "release_read_lease",
              "create_worktree",
              "acquire_write_lock",
              "release_write_lock",
              "run_baseline",
              "run_verification",
              "cleanup_worktree"
            ]
          },
          "repo": { "type": "string" },
          "project": { "type": "string" },
          "branch": { "type": "string" },
          "checkout": { "type": "string" },
          "worktree": { "type": "string" },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reason": { "type": "string" }
        }
      }
    },
    "targetPatch": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["unknown", "no-code", "parent", "code"]
        },
        "status": {
          "type": "string",
          "enum": ["unresolved", "inferred", "confirmed"]
        },
        "repo": { "type": ["string", "null"] },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "detail"],
            "properties": {
              "source": { "type": "string" },
              "detail": { "type": "string" }
            }
          }
        }
      }
    },
    "discoveryReport": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "required": [
        "issueId",
        "target",
        "repoHead",
        "baseBranch",
        "inspectedPaths",
        "likelyChangeAreas",
        "verificationCandidates",
        "unknowns",
        "createdAt",
        "freshness"
      ],
      "properties": {
        "issueId": { "type": "string" },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "status", "repo", "confidence", "evidence"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["unknown", "no-code", "parent", "code"]
            },
            "status": {
              "type": "string",
              "enum": ["unresolved", "inferred", "confirmed"]
            },
            "repo": { "type": ["string", "null"] },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source", "detail"],
                "properties": {
                  "source": { "type": "string" },
                  "detail": { "type": "string" }
                }
              }
            }
          }
        },
        "repoHead": { "type": "string" },
        "baseBranch": { "type": "string" },
        "inspectedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "likelyChangeAreas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verificationCandidates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unknowns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string" },
        "freshness": { "type": "object" }
      }
    },
    "executionBrief": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "required": [
        "goal",
        "nonGoals",
        "acceptanceCriteria",
        "target",
        "discoveryReportRef",
        "likelyChangeAreas",
        "verification",
        "risks",
        "rollback"
      ],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "nonGoals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "status", "repo", "confidence", "evidence"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["unknown", "no-code", "parent", "code"]
            },
            "status": {
              "type": "string",
              "enum": ["unresolved", "inferred", "confirmed"]
            },
            "repo": { "type": ["string", "null"] },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source", "detail"],
                "properties": {
                  "source": { "type": "string" },
                  "detail": { "type": "string" }
                }
              }
            }
          }
        },
        "discoveryReportRef": { "type": ["string", "null"] },
        "likelyChangeAreas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification": {
          "type": "object",
          "additionalProperties": true,
          "required": ["commands", "unavailableReason"],
          "properties": {
            "commands": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unavailableReason": { "type": ["string", "null"] }
          }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rollback": { "type": "string" }
      }
    },
    "requiresHuman": {
      "type": "boolean"
    }
  }
}
